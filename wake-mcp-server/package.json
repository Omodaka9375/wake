{
  "name": "wake-mcp-server",
  "version": "2.0.0",
  "description": "WAKE Protocol — Will-Aware Knowledge Execution. A post-mortem protocol for AI agents.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "wake-mcp-server": "build/index.js"
  },
  "files": [
    "build/",
    "dashboard/",
    "SKILL.md",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "start:http": "node build/index.js --http",
    "test": "node build/test.js",
    "prepare": "tsc",
    "dev": "tsc --watch",
    "check": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "wake",
    "protocol",
    "agent",
    "post-mortem",
    "digital-estate",
    "succession",
    "ai-agents"
  ],
  "author": "Omodaka9375 (https://github.com/Omodaka9375)",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/Omodaka9375/wake-mcp-server"
  },
  "homepage": "https://github.com/Omodaka9375/wake-mcp-server#readme",
  "bugs": {
    "url": "https://github.com/Omodaka9375/wake-mcp-server/issues"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@cfworker/json-schema": "^4.1.1",
    "@modelcontextprotocol/node": "2.0.0-alpha.2",
    "@modelcontextprotocol/server": "2.0.0-alpha.2",
    "@types/better-sqlite3": "^7.6.13",
    "better-sqlite3": "^12.9.0",
    "typescript": "^6.0.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@modelcontextprotocol/client": "2.0.0-alpha.2",
    "@types/node": "^25.6.0"
  }
}
