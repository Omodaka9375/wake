{
  "version": 2,
  "builds": [
    {
      "src": "build/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "dashboard/**",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/tool", "dest": "build/index.js" },
    { "src": "/mcp", "dest": "build/index.js" },
    { "src": "/(.*)", "dest": "dashboard/$1" }
  ]
}
